[50.561622, "i", "\u001bOB"]
[50.56268, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[01;31mRETURN\u001b[00m \u001b[01;31mVALUE\u001b[00m\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page sbrk(2) line 2 (press h for help or q to quit)\u001b[00m\u001b[K"]
[51.061858, "i", "\u001bOB"]
[51.063048, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       On success, \u001b[01;31mbrk\u001b[00m() returns zero.  On error, -1 is returned, and \u001b[01;32merrno\u001b[00m is set to \u001b[01;31mENOMEM\u001b[00m.\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page sbrk(2) line 3 (press h for help or q to quit)\u001b[00m\u001b[K"]
[51.14569, "i", "\u001bOB"]
[51.146652, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page sbrk(2) line 4 (press h for help or q to quit)\u001b[00m\u001b[K"]
[51.227059, "i", "\u001bOB"]
[51.227664, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[51.227897, "o", "       On success, \u001b[01;31msbrk\u001b[00m() returns the previous program break.  (If the break was increased, then this value is  a  pointer  to\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page sbrk(2) line 5 (press h for help or q to quit)\u001b[00m\u001b[K"]
[51.311679, "i", "\u001bOB"]
[51.312184, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       the start of the newly allocated memory).  On error, \u001b[01;32m(void\u001b[00m \u001b[01;32m*)\u001b[00m \u001b[01;32m-1\u001b[00m is returned, and \u001b[01;32merrno\u001b[00m is set to \u001b[01;31mENOMEM\u001b[00m.\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page sbrk(2) line 6 (press h for help or q to quit)\u001b[00m\u001b[K"]
[51.394247, "i", "\u001bOB"]
