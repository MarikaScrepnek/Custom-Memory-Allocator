[89.051787, "i", "\u001bOB"]
[89.053204, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       Various systems use various types for the argument of \u001b[01;31msbrk\u001b[00m().  Common are \u001b[01;32mint\u001b[00m, \u001b[01;32mssize_t\u001b[00m, \u001b[01;32mptrdiff_t\u001b[00m, \u001b[01;32mintptr_t\u001b[00m.\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page sbrk(2) line 18 (press h for help or q to quit)\u001b[00m\u001b[K"]
