[527.758418, "o", "\u001b[01;32mperror\u001b[00m(3)                                          Library Functions Manual                                          \u001b[01;32mperror\u001b[00m(3)\u001b[m\r\n\u001b[m\r\n\u001b[01;31mNAME\u001b[00m\u001b[m\r\n       perror - print a system error message\u001b[m\r\n\u001b[m\r\n\u001b[01;31mLIBRARY\u001b[00m\u001b[m\r\n       Standard C library (\u001b[01;32mlibc\u001b[00m, \u001b[01;32m-lc\u001b[00m)\u001b[m\r\n\u001b[m\r\n\u001b[01;31mSYNOPSIS\u001b[00m\u001b[m\r\n       \u001b[01;31m#include\u001b[00m \u001b[01;31m<stdio.h>\u001b[00m\u001b[m\r\n\u001b[m\r\n       \u001b[01;31mvoid\u001b[00m \u001b[01;31mperror(const\u001b[00m \u001b[01;31mchar\u001b[00m \u001b[01;31m*\u001b[00m\u001b[01;32ms\u001b[00m\u001b[01;31m);\u001b[00m\u001b[m\r\n\u001b[m\r\n       \u001b[01;31m#include\u001b[00m \u001b[01;31m<errno.h>\u001b[00m\u001b[m\r\n\u001b[m\r\n       \u001b[01;31mint\u001b[00m \u001b[01;32merrno\u001b[00m\u001b[01;31m;\u001b[00m       /* Not really declared this way; see errno(3) */\u001b[m\r\n\u001b[m\r\n       \u001b[01;31m[[deprecated]]\u001b[00m \u001b[01;31mconst\u001b[00m \u001b[01;31mchar\u001b[00m \u001b[01;31m*const\u001b[00m \u001b[01;32msys_errlist\u001b[00m\u001b[01;31m[];\u001b[00m\u001b[m\r\n       \u001b[01;31m[[deprecated]]\u001b[00m \u001b[01;31mint\u001b[00m \u001b[01;32msys_nerr\u001b[00m\u001b[01;31m;\u001b[00m\u001b[m\r\n\u001b[m\r\n   Feature Test Macro Requirements for glibc (see \u001b[01;31mfeature_test_macros\u001b[00m(7)):\u001b[m\r\n\u001b[m\r\n       \u001b[01;32msys_errlist\u001b[00m, \u001b[01;32msys_nerr\u001b[00m:\u001b[m\r\n           From glibc 2.19 to glibc 2.31:\u001b[m\r\n               _DEFAULT_SOURCE\u001b[m\r\n           glibc 2.19 and earlier:\u001b[m\r\n               _BSD_SOURCE\u001b[m\r\n\u001b[m\r\n\u001b[01;31mDESCRIPTION\u001b[00m\u001b[m\r\n       The  \u001b[01;31mperror\u001b[00m()  function  produces  a message on standard error describing the last error encountered during a call to a\u001b[m\r\n       system or library function.\u001b[m\r\n\u001b[m\r\n       First (if \u001b[01;32ms\u001b[00m is not NULL and \u001b[01;32m*s\u001b[00m is not a null byte ('\\0')), the argument string \u001b[01;32ms\u001b[00m is printed, followed by a colon and  a\u001b[m\r\n       blank.  Then an error message corresponding to the current value of \u001b[01;32merrno\u001b[00m and a new-line.\u001b[m\r\n\u001b[m\r\n       To be of most use, the argument string should include the name of the function that incurred the error.\u001b[m\r\n\u001b[m\r\n       The global error list \u001b[01;32msys_errlist\u001b[00m[], which can be indexed by \u001b[01;32merrno\u001b[00m, can be used to obtain the error message without the\u001b[m\r\n       newline.   The  largest  message  number  provided in the table is \u001b[01;32msys_nerr\u001b[00m-1.  Be careful when directly accessing this\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page perror(3) line 1 (press h for help or q to quit)\u001b[00m\u001b[K"]
