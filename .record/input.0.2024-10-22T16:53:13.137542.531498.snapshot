[263.501849, "o", "\u001b[?1049h\u001b[22;0;0t\u001b[?1h\u001b=\r"]
[263.6058, "o", "\u001b[01;32mbrk\u001b[00m(2)                                                System Calls Manual                                               \u001b[01;32mbrk\u001b[00m(2)\u001b[m\r\n\u001b[m\r\n\u001b[01;31mNAME\u001b[00m\u001b[m\r\n       brk, sbrk - change data segment size\u001b[m\r\n\u001b[m\r\n\u001b[01;31mLIBRARY\u001b[00m\u001b[m\r\n       Standard C library (\u001b[01;32mlibc\u001b[00m, \u001b[01;32m-lc\u001b[00m)\u001b[m\r\n\u001b[m\r\n\u001b[01;31mSYNOPSIS\u001b[00m\u001b[m\r\n       \u001b[01;31m#include\u001b[00m \u001b[01;31m<unistd.h>\u001b[00m\u001b[m\r\n\u001b[m\r\n       \u001b[01;31mint\u001b[00m \u001b[01;31mbrk(void\u001b[00m \u001b[01;31m*\u001b[00m\u001b[01;32maddr\u001b[00m\u001b[01;31m);\u001b[00m\u001b[m\r\n       \u001b[01;31mvoid\u001b[00m \u001b[01;31m*sbrk(intptr_t\u001b[00m \u001b[01;32mincrement\u001b[00m\u001b[01;31m);\u001b[00m\u001b[m\r\n\u001b[m\r\n   Feature Test Macro Requirements for glibc (see \u001b[01;31mfeature_test_macros\u001b[00m(7)):\u001b[m\r\n\u001b[m\r\n       \u001b[01;31mbrk\u001b[00m(), \u001b[01;31msbrk\u001b[00m():\u001b[m\r\n           Since glibc 2.19:\u001b[m\r\n               _DEFAULT_SOURCE\u001b[m\r\n                   || ((_XOPEN_SOURCE >= 500) &&\u001b[m\r\n                       ! (_POSIX_C_SOURCE >= 200112L))\u001b[m\r\n           From glibc 2.12 to glibc 2.19:\u001b[m\r\n               _BSD_SOURCE || _SVID_SOURCE\u001b[m\r\n                   || ((_XOPEN_SOURCE >= 500) &&\u001b[m\r\n                       ! (_POSIX_C_SOURCE >= 200112L))\u001b[m\r\n           Before glibc 2.12:\u001b[m\r\n               _BSD_SOURCE || _SVID_SOURCE || _XOPEN_SOURCE >= 500\u001b[m\r\n\u001b[m\r\n\u001b[01;31mDESCRIPTION\u001b[00m\u001b[m\r\n       \u001b[01;31mbrk\u001b[00m()  and  \u001b[01;31msbrk\u001b[00m() change the location of the \u001b[01;32mprogram\u001b[00m \u001b[01;32mbreak\u001b[00m, which defines the end of the process's data segment (i.e.,\u001b[m\r\n       the program break is the first location after the end of the uninitialized data segment).  Increasing the program break\u001b[m\r\n       has the effect of allocating memory to the process; decreasing the break deallocates memory.\u001b[m\r\n\u001b[m\r\n       \u001b[01;31mbrk\u001b[00m() sets the end of the data segment to the value specified by \u001b[01;32maddr\u001b[00m, when that value is reasonable,  the  system  has\u001b[m\r\n       enough memory, and the process does not exceed its maximum data size (see \u001b[01;31msetrlimit\u001b[00m(2)).\u001b[m\r\n\u001b[m\r\n       \u001b[01;31msbrk\u001b[00m()  increments  the  program's data space by \u001b[01;32mincrement\u001b[00m"]
[263.605981, "o", " bytes.  Calling \u001b[01;31msbrk\u001b[00m() with an \u001b[01;32mincrement\u001b[00m of 0 can be used to\u001b[m\r\n       find the current location of the program break.\u001b[m\r\n\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page sbrk(2) line 1 (press h for help or q to quit)\u001b[00m\u001b[K"]
[273.438077, "i", "\u001bOB"]
[273.439057, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[01;31mRETURN\u001b[00m \u001b[01;31mVALUE\u001b[00m\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page sbrk(2) line 2 (press h for help or q to quit)\u001b[00m\u001b[K"]
[273.929597, "i", "\u001bOB"]
[273.930413, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       On success, \u001b[01;31mbrk\u001b[00m() returns zero.  On error, -1 is returned, and \u001b[01;32merrno\u001b[00m is set to \u001b[01;31mENOMEM\u001b[00m.\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page sbrk(2) line 3 (press h for help or q to quit)\u001b[00m\u001b[K"]
[274.013182, "i", "\u001bOB"]
[274.014, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page sbrk(2) line 4 (press h for help or q to quit)\u001b[00m\u001b[K"]
[274.096915, "i", "\u001bOB"]
[274.097377, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       On success, \u001b[01;31msbrk\u001b[00m() returns the previous program break.  (If the break was increased, then this value is  a  pointer  to\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page sbrk(2) line 5 (press h for help or q to quit)\u001b[00m\u001b[K"]
[274.181159, "i", "\u001bOB"]
[274.181671, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       the start of the newly allocated memory).  On error, \u001b[01;32m(void\u001b[00m \u001b[01;32m*)\u001b[00m \u001b[01;32m-1\u001b[00m is returned, and \u001b[01;32merrno\u001b[00m is set to \u001b[01;31mENOMEM\u001b[00m.\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page sbrk(2) line 6 (press h for help or q to quit)\u001b[00m\u001b[K"]
[274.264141, "i", "\u001bOB"]
[274.264715, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[01;33m\u001b[44m Manual page sbrk(2) line 7 (press h for help or q to quit)\u001b[00m\u001b[K"]
[274.350588, "i", "\u001bOB"]
[274.351443, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[01;31mSTANDARDS\u001b[00m\u001b[m\r\n"]
[274.351895, "o", "\u001b[01;33m\u001b[44m Manual page sbrk(2) line 8 (press h for help or q to quit)\u001b[00m\u001b[K"]
[274.436175, "i", "\u001bOB"]
